<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="Raymond Extends Explorer"
           Manufacturer="Raymond"
           Version="$(var.Version)"
           UpgradeCode="A3F2B8C1-7D4E-4A9F-B6E5-1C8D3F2A7B9E"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="RaymondExtendsExplorer">

        <Component Id="MainExecutable" Guid="D4E5F6A7-B8C9-4D0E-A1F2-3B4C5D6E7F80">
          <File Id="ExeFile" Source="$(RaymondExtendsExplorer.TargetDir)\RaymondExtendsExplorer.exe" KeyPath="yes" />
          <File Id="DllFile" Source="$(RaymondExtendsExplorer.TargetDir)\RaymondExtendsExplorer.dll" />
          <File Id="DepsJson" Source="$(RaymondExtendsExplorer.TargetDir)\RaymondExtendsExplorer.deps.json" />
          <File Id="RuntimeConfig" Source="$(RaymondExtendsExplorer.TargetDir)\RaymondExtendsExplorer.runtimeconfig.json" />
          <File Id="AppIcon" Source="$(RaymondExtendsExplorer.ProjectDir)\app.ico" />

          <!-- Flatten Structure - folder context menu (alphabetically first) -->
          <RegistryValue Root="HKCR" Key="Directory\shell\RaymondFlattenStructure"
                         Value="Flatten Structure" Type="string" />
          <RegistryValue Root="HKCR" Key="Directory\shell\RaymondFlattenStructure"
                         Name="Icon" Value="&quot;[INSTALLFOLDER]app.ico&quot;" Type="string" />
          <RegistryValue Root="HKCR" Key="Directory\shell\RaymondFlattenStructure"
                         Name="SeparatorBefore" Value="" Type="string" />
          <RegistryValue Root="HKCR" Key="Directory\shell\RaymondFlattenStructure\command"
                         Value="&quot;[INSTALLFOLDER]RaymondExtendsExplorer.exe&quot; flatten-structure &quot;%V&quot;"
                         Type="string" />

          <!-- Moved to Just Watched - folder context menu -->
          <RegistryValue Root="HKCR" Key="Directory\shell\RaymondMoveToJustWatched"
                         Value="Moved to Just Watched" Type="string" />
          <RegistryValue Root="HKCR" Key="Directory\shell\RaymondMoveToJustWatched"
                         Name="Icon" Value="&quot;[INSTALLFOLDER]app.ico&quot;" Type="string" />
          <RegistryValue Root="HKCR" Key="Directory\shell\RaymondMoveToJustWatched\command"
                         Value="&quot;[INSTALLFOLDER]RaymondExtendsExplorer.exe&quot; move-to-just-watched &quot;%V&quot;"
                         Type="string" />

          <!-- Set all files as today - folder context menu -->
          <RegistryValue Root="HKCR" Key="Directory\shell\RaymondSetToday"
                         Value="Set all files as today" Type="string" />
          <RegistryValue Root="HKCR" Key="Directory\shell\RaymondSetToday"
                         Name="Icon" Value="&quot;[INSTALLFOLDER]app.ico&quot;" Type="string" />
          <RegistryValue Root="HKCR" Key="Directory\shell\RaymondSetToday\command"
                         Value="&quot;[INSTALLFOLDER]RaymondExtendsExplorer.exe&quot; set-today &quot;%V&quot;"
                         Type="string" />

          <!-- Toggle Confirmations - folder context menu (alphabetically last) -->
          <RegistryValue Root="HKCR" Key="Directory\shell\RaymondToggleConfirmations"
                         Value="Toggle Confirmations" Type="string" />
          <RegistryValue Root="HKCR" Key="Directory\shell\RaymondToggleConfirmations"
                         Name="Icon" Value="&quot;[INSTALLFOLDER]app.ico&quot;" Type="string" />
          <RegistryValue Root="HKCR" Key="Directory\shell\RaymondToggleConfirmations"
                         Name="SeparatorAfter" Value="" Type="string" />
          <RegistryValue Root="HKCR" Key="Directory\shell\RaymondToggleConfirmations\command"
                         Value="&quot;[INSTALLFOLDER]RaymondExtendsExplorer.exe&quot; toggle-confirmations"
                         Type="string" />

          <!-- Move to Show Folder - file context menu (alphabetically first) -->
          <RegistryValue Root="HKCR" Key="*\shell\RaymondMoveToShowFolder"
                         Value="Move to Show Folder" Type="string" />
          <RegistryValue Root="HKCR" Key="*\shell\RaymondMoveToShowFolder"
                         Name="Icon" Value="&quot;[INSTALLFOLDER]app.ico&quot;" Type="string" />
          <RegistryValue Root="HKCR" Key="*\shell\RaymondMoveToShowFolder"
                         Name="SeparatorBefore" Value="" Type="string" />
          <RegistryValue Root="HKCR" Key="*\shell\RaymondMoveToShowFolder\command"
                         Value="&quot;[INSTALLFOLDER]RaymondExtendsExplorer.exe&quot; move-to-show-folder &quot;%V&quot;"
                         Type="string" />

          <!-- Move episode to JustWatched - file context menu -->
          <RegistryValue Root="HKCR" Key="*\shell\RaymondMoveEpisodeToJustWatched"
                         Value="Move episode to JustWatched" Type="string" />
          <RegistryValue Root="HKCR" Key="*\shell\RaymondMoveEpisodeToJustWatched"
                         Name="Icon" Value="&quot;[INSTALLFOLDER]app.ico&quot;" Type="string" />
          <RegistryValue Root="HKCR" Key="*\shell\RaymondMoveEpisodeToJustWatched"
                         Name="SeparatorAfter" Value="" Type="string" />
          <RegistryValue Root="HKCR" Key="*\shell\RaymondMoveEpisodeToJustWatched\command"
                         Value="&quot;[INSTALLFOLDER]RaymondExtendsExplorer.exe&quot; move-episode-to-just-watched &quot;%V&quot;"
                         Type="string" />

          <!-- Set all files as today - file context menu -->
          <RegistryValue Root="HKCR" Key="*\shell\RaymondSetToday"
                         Value="Set all files as today" Type="string" />
          <RegistryValue Root="HKCR" Key="*\shell\RaymondSetToday"
                         Name="Icon" Value="&quot;[INSTALLFOLDER]app.ico&quot;" Type="string" />
          <RegistryValue Root="HKCR" Key="*\shell\RaymondSetToday"
                         Name="SeparatorAfter" Value="" Type="string" />
          <RegistryValue Root="HKCR" Key="*\shell\RaymondSetToday\command"
                         Value="&quot;[INSTALLFOLDER]RaymondExtendsExplorer.exe&quot; set-today &quot;%V&quot;"
                         Type="string" />
        </Component>

      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="Raymond Extends Explorer" Level="1">
      <ComponentRef Id="MainExecutable" />
    </Feature>

  </Package>

</Wix>
